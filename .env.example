# ws-scrcpy Auto-Connect Configuration
# =====================================
# These environment variables configure single-device auto-connect mode

# Device Configuration
# --------------------
# The device hostname/IP and optional port to connect to via ADB
# Examples:
#   - Local emulator: emulator-5554
#   - Redroid in Docker: redroid:5555
#   - Remote device: 192.168.1.100:5555
SCRCPY_DEVICE_HOST=emulator-5554

# Alternative variable name (for backwards compatibility)
# SCRCPY_DEVICE_UDID=emulator-5554

# scrcpy Server Configuration
# ---------------------------
# The port where scrcpy WebSocket server listens on the Android device
# Default: 8886 (defined in src/common/Constants.ts)
# SCRCPY_DEVICE_PORT=8886

# ws-scrcpy Server Configuration
# ------------------------------
# The port where ws-scrcpy HTTP/WebSocket server listens
# Default: 8000 (defined in src/server/Config.ts)
# WS_SCRCPY_SERVER_PORT=8000
